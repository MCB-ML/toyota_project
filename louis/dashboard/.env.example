# Anthropic API key for the AI chatbot feature
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# MS login (MSAL) — from the Entra ID app registration (single-tenant)
VITE_AZURE_AD_CLIENT_ID=
VITE_AZURE_AD_TENANT_ID=

# KTWS BI (Power BI / Fabric) — report embedded via powerbi-client SSO'd off the MSAL login above
VITE_POWERBI_REPORT_ID=
VITE_POWERBI_GROUP_ID=

# Fabric Data Warehouse SQL 엔드포인트 (Agora/Karete/BP_KTWS) — server/fabricClient.js
# 본인 Azure AD 계정(예: TMKR_Account@toyotamotor.co.kr)의 아이디/비밀번호를 그대로 입력
Fabric_ID=
Fabric_PW=
# 아래 둘은 보통 비워둬도 됨 (기본값이 fabricClient.js에 있음) — 로그인 실패 시에만 채울 것
FABRIC_SQL_CLIENT_ID=
FABRIC_SQL_TENANT_ID=

# 로컬 Postgres (본사/딜러사별 KTWS 대시보드 커스텀 레이아웃 저장) — docker-compose.yml 참고
# 5433 사용: 이 PC에 이미 5432로 떠 있는 네이티브 Postgres와 충돌 방지
PG_HOST=localhost
PG_PORT=5433
PG_USER=dashboard
PG_PASSWORD=dashboard
PG_DATABASE=toyota_dashboard

# 로컬 ChromaDB (rag-poc/ 벡터 검색용) — docker-compose.yml 참고
CHROMA_PORT=8000
CHROMA_URL=http://localhost:8000
