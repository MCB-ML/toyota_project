{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ktws-agentic-bi/schemas/dashboard_ir.schema.json",
  "title": "DashboardIR",
  "description": "LLM은 JSX/ECharts 옵션을 직접 생성하지 않는다 — 이 구조만 생성하고, React는 component_registry.yaml에 등록된 컴포넌트만 결정론적으로 렌더링한다.",
  "type": "object",
  "additionalProperties": false,
  "required": ["dashboard_id", "title", "layout", "components"],
  "properties": {
    "dashboard_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "global_filters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "type"],
        "properties": {
          "field": { "type": "string" },
          "type": { "type": "string", "enum": ["multi_select", "single_select", "month", "date_range"] }
        }
      },
      "default": []
    },
    "layout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["columns", "row_height"],
      "properties": {
        "columns": { "type": "integer", "minimum": 1, "maximum": 24 },
        "row_height": { "type": "integer", "minimum": 20 }
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": { "$ref": "#/$defs/Component" }
    }
  },
  "$defs": {
    "Component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "title", "query_ref", "position"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "type": "string",
          "description": "component_registry.yaml에 등록된 컴포넌트만 허용 — 이 enum은 registry와 동기화되어야 함(dashboard_ir_validator.js가 실제 소스 오브 트루스)",
          "enum": [
            "kpi_card", "metric_comparison", "line_chart", "bar_chart",
            "stacked_bar_chart", "donut_chart", "funnel_chart", "scatter_chart",
            "heatmap", "detail_table", "risk_table", "narrative", "filter", "alert"
          ]
        },
        "title": { "type": "string" },
        "query_ref": { "type": "string", "description": "semanticQueries/compiledQueries 중 하나를 가리키는 식별자 — 존재하지 않으면 DashboardIRValidator가 거부" },
        "metric": { "type": "string" },
        "x": { "type": "string" },
        "y": { "type": "array", "items": { "type": "string" } },
        "label_key": { "type": "string" },
        "value_key": { "type": "string" },
        "position": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y", "w", "h"],
          "properties": {
            "x": { "type": "integer", "minimum": 0 },
            "y": { "type": "integer", "minimum": 0 },
            "w": { "type": "integer", "minimum": 1 },
            "h": { "type": "integer", "minimum": 1 }
          }
        }
      }
    }
  }
}
